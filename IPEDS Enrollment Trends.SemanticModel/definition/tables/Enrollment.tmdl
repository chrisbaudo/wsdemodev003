	column Year
		isHidden
		formatString: 0
		lineageTag: 22f72337-e801-4399-a5a7-cc68648e2dbe
		summarizeBy: none
		isNameInferred
		sourceColumn: Enrollment by Year[Year]

		annotation SummarizationSetBy = User

	column Enrollment
		formatString: #,0
		lineageTag: 680c540d-b87d-4000-b8e6-2289fd03cd5c
		summarizeBy: sum
		isNameInferred
		sourceColumn: Enrollment by Year[Enrollment]

		annotation SummarizationSetBy = Automatic

	partition Table-66e94933-4694-4227-9a9d-87993bbf4e25 = calculated
		mode: import
		source = FILTER('Enrollment by Year','Enrollment by Year'[InstituteID] = RELATED(Institution[Institute ID]))

