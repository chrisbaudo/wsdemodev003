	column weekday_number
		formatString: 0
		lineageTag: e374729f-418a-4743-bd4e-8fdfb09309b2
		summarizeBy: sum
		isNameInferred
		sourceColumn: [weekday_number]

		annotation SummarizationSetBy = Automatic

	column weekday_name
		lineageTag: 8c6b660a-7d26-40b4-ae34-f22d19636f14
		summarizeBy: none
		isNameInferred
		sourceColumn: [weekday_name]

