table date
	lineageTag: 6e2a04f0-01cd-4734-9fb6-ba7995af0cfd
	dataCategory: Time

	column date
		isKey
		formatString: Short Date
		lineageTag: 32d1ec63-077a-4ee6-af86-9064184ac31d
		summarizeBy: none
		sourceColumn: [Date]

		annotation SummarizationSetBy = Automatic

		annotation UnderlyingDateTimeDataType = Date

	column year
		formatString: 0
		lineageTag: 72fbd224-85f8-4f9f-abcd-c90e99a2a5ce
		summarizeBy: sum
		isNameInferred
		sourceColumn: [Year]

		annotation SummarizationSetBy = Automatic

	column quarter
		lineageTag: e1720f1b-f084-4c2a-b83a-c5ce270f5bea
		summarizeBy: none
		isNameInferred
		sourceColumn: [Quarter]

		annotation SummarizationSetBy = Automatic

	column month_number
		formatString: 0
		lineageTag: 66a1c1fb-43c8-4740-bc97-ecbd437271ee
		summarizeBy: sum
		isNameInferred
		sourceColumn: [month_number]

		annotation SummarizationSetBy = Automatic

	column month_name
		lineageTag: 7024b749-7206-441c-a56d-48f6bb1d54f2
		summarizeBy: none
		isNameInferred
		sourceColumn: [month_name]

