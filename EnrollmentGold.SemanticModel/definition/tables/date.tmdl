	column year_month
		lineageTag: f0c7d441-177e-43f3-a3af-1bb6329ada3f
		summarizeBy: none
		isNameInferred
		sourceColumn: [year_month]

		annotation SummarizationSetBy = Automatic

	partition date = calculated
		mode: import
		source =
				
				ADDCOLUMNS(
				    CALENDAR(DATE(2010,1,1), DATE(2030,12,31)),
				    "year", YEAR([Date]),
				    "month_number", MONTH([Date]),
				    "month_name", FORMAT([Date], "MMMM"),
				    "quarter", "Q" & FORMAT([Date], "Q"),
				    "weekday_number", WEEKDAY([Date]),
				    "weekday_name", FORMAT([Date], "dddd"),
				    "year_month", FORMAT([Date], "YYYY-MM")
				)

	annotation PBI_Id = 47921bd0154c4d448baed7fb8d2dc34c

